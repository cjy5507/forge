{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "scripts/**/*.mjs",
    "scripts/**/*.ts",
    "types/**/*.d.ts"
  ]
}
